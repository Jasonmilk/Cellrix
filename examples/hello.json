{
  "version": "2.3",
  "layout": {
    "direction": "vertical",
    "slots": [
      { "id": "header", "weight": 1 },
      { "id": "main", "weight": 6,
        "layout": {
          "direction": "vertical",
          "slots": [
            { "id": "progress_area", "weight": 1 },
            { "id": "table_area", "weight": 3 },
            { "id": "list_area", "weight": 2 }
          ]
        }
      },
      { "id": "footer", "weight": 1 }
    ]
  },
  "cells": [
    {
      "id": "title",
      "type": "static",
      "slot": "header",
      "content": "Cellrix — Intent-Driven Terminal UI Protocol",
      "role": "title"
    },
    {
      "id": "progress_demo",
      "type": "dynamic",
      "slot": "progress_area",
      "semantic_widget": "progress",
      "semantic_data": 75
    },
    {
      "id": "table_demo",
      "type": "dynamic",
      "slot": "table_area",
      "semantic_widget": "table",
      "semantic_data": [
        ["Feature", "Status"],
        ["Layout Solver", "✅ Pure"],
        ["Theme Tokens", "✅ 10"],
        ["CIS Intents", "✅ v0.6"],
        ["Agent API", "✅ <10ms"]
      ]
    },
    {
      "id": "list_demo",
      "type": "dynamic",
      "slot": "list_area",
      "semantic_widget": "list",
      "semantic_data": [
        "Tab → move focus",
        "? → shortcuts",
        "q → quit"
      ]
    },
    {
      "id": "status",
      "type": "static",
      "slot": "footer",
      "content": "All systems nominal | Theme: Dracula (default)",
      "role": "footer"
    }
  ]
}
