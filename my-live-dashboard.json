{
  "version": "2.3",
  "layout": {
    "direction": "horizontal",
    "slots": [
      { "id": "left", "weight": 1 },
      { "id": "right", "weight": 2, "layout": {
        "direction": "vertical",
        "slots": [
          { "id": "top", "weight": 1 },
          { "id": "bottom", "weight": 2 }
        ]
      }}
    ]
  },
  "cells": [
    { "id": "nav", "type": "static", "slot": "left",
      "content": "🚀 Live Dashboard\n\nProgress: live\nEvents: scrollable",
      "minConstraint": { "width": 15, "height": 5 }, "priority": 100 },
    { "id": "progress", "type": "realtime", "slot": "top",
      "semantic_widget": "progress",
      "source": { "type": "pipe", "command": "while true; do echo $((RANDOM % 100)); sleep 1; done" },
      "content": "Loading..." },
    { "id": "events", "type": "dynamic", "slot": "bottom",
      "collapseMode": "scroll",
      "content": "Waiting for events..." }
  ]
}
