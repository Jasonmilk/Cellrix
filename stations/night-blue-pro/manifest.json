      "role": "sidebar"
    },
    {
      "id": "main_panel_content",
      "type": "static",
      "slot": "main_view",
      "content": "Main business display & operation area",
      "role": "body"
    },
    {
      "id": "copyright_info",
      "type": "static",
      "slot": "footer",
      "content": "Powered by Cellrix Design System",
      "role": "footer"
    }
  ]
}
