{
  "version": "2.3",
  "layout": {
    "direction": "vertical",
    "slots": [
      {
        "id": "top_bar",
        "weight": 1
      },
      {
        "id": "sidebar",
        "weight": 2
      },
      {
        "id": "main_view",
        "weight": 6
      },
      {
        "id": "footer",
        "weight": 1
      }
    ]
  },
  "cells": [
    {
      "id": "app_header",
      "type": "static",
